{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "案件看板",
  "version": "0.3.26",
  "identifier": "app.caseboard.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "案件看板",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "resources": {
      "../standalone/court_filing_cli": "standalone/court_filing_cli"
    },
    "shortDescription": "律师案件看板",
    "longDescription": "CaseBoard 案件看板 — 律师自己在办案件的可视化看板,本地优先、不改动源文件。把文件夹里的诉讼材料一拖,关键信息自动抽出,8 档智能状态机管理案件进展,内置 5 个法律计算工具。",
    "copyright": "Copyright © 2026 CaseBoard Contributors",
    "publisher": "CaseBoard",
    "homepage": "https://www.lawtools.top/",
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVBQTlBM0I1MThGOUQ4MjUKUldRbDJQa1l0YU9wV3MwSnI0U2ROK0JsWFZzOCtJWUxvMW9OeHlOaDRObjVPMnVXODdQbHE4SHgK",
      "endpoints": [
        "https://lawtools.top/caseboard/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
