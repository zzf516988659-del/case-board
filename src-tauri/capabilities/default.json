{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "案件看板主窗口能力集",
  "windows": ["main", "chat-*"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "opener:default",
    "dialog:default",
    "fs:default",
    "fs:allow-read-file",
    "updater:default",
    "process:default",
    "process:allow-restart",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$TEMP/**" }
      ]
    }
  ]
}
